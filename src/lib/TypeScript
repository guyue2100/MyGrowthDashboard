// src/lib/gtag.ts
export const GA_TRACKING_ID = 'G-0MTELQGND1';

export const trackEvent = (action: string, { category, label, value }: {
  category: string;
  label?: string;
  value?: number;
}) => {
  if (typeof window !== 'undefined' && (window as any).gtag) {
    (window as any).gtag('event', action, {
      event_category: category,
      event_label: label,
      value: value,
    });
  }
};
